{
    "name": "belajar/php-composer",
    "description": "Belajar composer, autoloading, dan third-party packages di PHP",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vlucas/phpdotenv": "^5.6",
        "nesbot/carbon": "^3.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/App/"
        }
    },
    "scripts": {
        "start": "php main.php",
        "check": "php main.php"
    },
    "config": {
        "optimize-autoloader": true
    }
}
